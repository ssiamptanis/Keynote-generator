# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — server only, never exposed to the browser. Currently
# unused by the app itself (RLS handles access) but kept available for
# future admin/back-office scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key for deck generation (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Restrict sign-in + the shared library to this email domain
ALLOWED_EMAIL_DOMAIN=gwi.com
